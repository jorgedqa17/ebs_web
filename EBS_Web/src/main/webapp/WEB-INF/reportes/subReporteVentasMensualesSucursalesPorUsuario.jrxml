	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="207"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="788"/>
	<parameter name="fechaInicio" class="java.lang.String"/>
	<parameter name="fechaFinal" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select tb.login, SUM(tb.TOTAL_COMPROBANTE) 
from (SELECT t1.LOGIN, t1.total_comprobante 
			FROM SEARMEDICA.FACTURA T1 
			where to_date(to_char(t1.fecha_factura, 'DD/MM/YYYY'),'DD/MM/YYYY') between to_date( $P{fechaInicio} ,'DD/MM/YYYY')  and to_date( $P{fechaFinal} ,'DD/MM/YYY') 
			AND T1.NUMERO_CONSECUTIVO IS NOT NULL
AND T1.ID_ANULACION IS NULL
			  ) 
tb GROUP BY tb.login]]>
	</queryString>
	<field name="login" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="login"/>
	</field>
	<field name="sum" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.label" value="sum"/>
	</field>
