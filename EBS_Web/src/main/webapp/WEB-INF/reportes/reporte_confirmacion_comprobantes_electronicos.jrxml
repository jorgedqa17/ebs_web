	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SearMedica_Desarrollo"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="rutaImagen" class="java.lang.String">
		<defaultValueExpression><![CDATA["C://SearMedica//PowerSystem//PowerSystem-web//src//main//webapp//resources//imagenes//"]]></defaultValueExpression>
	</parameter>
	<parameter name="idPago" class="java.lang.Long"/>
	<queryString>
		<![CDATA[SELECT id_pago, numero_consecutivo, fecha_emision, mensaje, clave_comprobante_pago, 
identificacion_proveedor, monto_impuestos, TO_CHAR(monto_total_comprobante, '99G999D99') AS monto_total_comprobante, id_estado, respuesta_hacienda, 
comprobante_enviado, correo_electronico, fecha_pago, 
 CASE
  WHEN (tipo_mensaje_respuesta = '05') THEN 'ACEPTADO'
  WHEN (tipo_mensaje_respuesta = '06')  THEN 'PARCIALMENTE ACEPTADO'
  WHEN (tipo_mensaje_respuesta = '07')  THEN 'RECHAZADO'
 END AS tipo_mensaje_respuesta
, documento_xml_firmado, detalle_respuesta_hacienda, tipo_identificacion_proveedor, mensaje_detalle, url_consulta_estado
	FROM searmedica.pago
where id_pago =  $P{idPago}]]>
	</queryString>
