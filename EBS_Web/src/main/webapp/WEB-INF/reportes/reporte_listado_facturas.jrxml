	<property name="property.name" value="false"/>
	<parameter name="fechaInicio" class="java.lang.String"/>
	<parameter name="fechaFinal" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT T1.ID_FACTURA, T1.NUMERO_CONSECUTIVO, TRIM(TO_CHAR(T1.FECHA_FACTURA,'DD/MM/YYYY') )AS FECHA_FACTURA,
trim(T2.DESCRIPCION) AS ESTADO,  T3.DESCRIPCION  ||(coalesce(t1.plazo_credito,''))||'-'||T6.DESCRIPCION AS CONDICION_VENTA, TRIM(T1.NOMBRE_CLIENTE_FANTASIA) AS NOMBRE_FANTASIA, 
TRIM((coalesce(t5.nombre,'') ||' '||coalesce(t5.primer_apellido,'')||' '||coalesce(t5.segundo_apellido,''))) as nombre , T1.TOTAL_COMPROBANTE
FROM SEARMEDICA.FACTURA T1 INNER JOIN SEARMEDICA.ESTADOS T2
ON T1.ESTADO_FACTURA = T2.ID_ESTADO INNER JOIN SEARMEDICA.CONDICION_VENTA T3
ON T1.ID_COND_VENTA = T3.ID_COND_VENTA LEFT JOIN SEARMEDICA.CLIENTE T4
ON T1.ID_CLIENTE = T4.ID_CLIENTE LEFT JOIN SEARMEDICA.PERSONA T5
ON T4.NUMERO_CEDULA = T5.NUMERO_CEDULA INNER JOIN SEARMEDICA.MEDIO_PAGO T6
ON T1.ID_MEDIO_PAGO = T6.ID_MEDIO_PAGO
WHERE T1.ID_ANULACION IS NULL
AND T1.NUMERO_CONSECUTIVO IS NOT NULL
AND T1.LOGIN = 'valeria'
AND T1.ID_COND_VENTA = 2
AND to_date(to_char(t1.fecha_factura, 'DD/MM/YYYY'),'DD/MM/YYYY') between to_date( $P{fechaInicio}  ,'DD/MM/YYYY')  and to_date(  $P{fechaFinal}  ,'DD/MM/YYY') 
 ORDER BY T1.ID_COND_VENTA desc , T6.ID_MEDIO_PAGO ASC, T1.FECHA_FACTURA ASC]]>
	</queryString>
