	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SearMedica_Desarrollo"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="221"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="774"/>
	<parameter name="idRecibo" class="java.lang.Long"/>
	<parameter name="montoLetras" class="java.lang.String"/>
	<parameter name="moneda" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT 
t1.id_recibo, t2.id_factura, t1.monto_pago, t1.monto_total_factura, 
t1.monto_restante, t1.fecha, t1.login, t4.numero_cedula,
(coalesce(t4.nombre,'') ||' '||coalesce(t4.primer_apellido,'')||' '||coalesce(t4.segundo_apellido,'')) as nombre_cliente, 
t5.nombre as nombre_facturador, t1.concepto_recibo, t2.clave, t2.numero_consecutivo, t6.descripcion as estado, t7.descripcion as medio_pago, t1.numero_referencia,
t1.es_recibo_manual, t1.numero_recibo_manual
FROM 
searmedica.recibo t1 left join searmedica.factura t2
on t1.id_factura = t2.id_factura left join searmedica.cliente t3
on t1.id_cliente = t3.id_cliente left join searmedica.persona t4
on t3.numero_cedula = t4.numero_cedula left join searmedica.usuario t5
on t1.login = t5.login left join searmedica.estados t6
on t1.id_estado = t6.id_estado left join searmedica.medio_pago t7
on t1.id_medio_pago = t7.id_medio_pago
WHERE t1.id_recibo =  $P{idRecibo}]]>
	</queryString>
