	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SearMedica_Desarrollo"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="idAnulacion" class="java.lang.Long"/>
	<parameter name="rutaImagen" class="java.lang.String">
		<defaultValueExpression><![CDATA["C://SearMedica//PowerSystem//PowerSystem-web//src//main//webapp//resources//imagenes//"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT T1.ID_ANULACION, T1.CLAVE AS CLAVE, T1.NUMERO_CONSECUTIVO, T2.CLAVE AS CLAVE_FACTURA, T2.NUMERO_CONSECUTIVO AS NUM_CONSEC_FACTURA,
T1.FECHA_EMISION, T3.DESCRIPCION AS ESTADO_DOCUMENTO, T4.DESCRIPCION AS MOTIVO_ANULACION, T1.MOTIVO_ANULACION AS RAZON_ANULACION, T1.FECHA_EMISION as fecha_emision
	FROM SEARMEDICA.FACTURA_ANULACION T1 INNER JOIN SEARMEDICA.FACTURA T2
	ON T1.ID_ANULACION = T2.ID_ANULACION INNER JOIN SEARMEDICA.ESTADOS T3
	ON T1.ID_ESTADO = T3.ID_ESTADO LEFT JOIN SEARMEDICA.MOTIVO_ANULACION T4
	ON T1.ID_MOTIVO_ANULACION = T4.ID_MOTIVO_ANULACION
	WHERE T1.ID_ANULACION =  $P{idAnulacion} ]]>
	</queryString>
