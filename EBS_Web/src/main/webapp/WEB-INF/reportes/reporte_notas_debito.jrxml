	<parameter name="idNotaDebito" class="java.lang.Long"/>
	<parameter name="rutaImagen" class="java.lang.String">
		<defaultValueExpression><![CDATA["C://SearMedica//PowerSystem//PowerSystem-web//src//main//webapp//resources//imagenes//"]]></defaultValueExpression>
	</parameter>
