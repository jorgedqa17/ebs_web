	</parameter>
	<queryString>
		<![CDATA[SELECT 
T1.ID_NOTA_DEBITO, T1.CLAVE AS CLAVE, T1.NUMERO_CONSECUTIVO, T2.CLAVE AS CLAVE_FACTURA, T2.NUMERO_CONSECUTIVO AS NUM_CONSEC_FACTURA,
T5.CLAVE AS CLAVE_NOTA_CREDITO, T5.NUMERO_CONSECUTIVO AS NUMERO_CONSECUTIVO_CREDITO,
T1.FECHA_EMISION, T3.DESCRIPCION AS ESTADO_DOCUMENTO, T4.DESCRIPCION AS MOTIVO_NOTA_DEBITO, T1.MOTIVO_NOTA_DEBITO AS RAZON_NOTA_DEBITO, T1.FECHA_EMISION as fecha_emision2,
T8.CANTIDAD, T9.DESCRIPCION,T8.TOTAL_IMPUESTOS,  T8.PRECIO_NETO, T8.TOTAL_LINEA,
T1.TOTAL_NOTA_DEBITO, T1.TOTAL_IMPUESTO, T1.LOGIN,
T10.TELEFONO_1, T10.TELEFONO_2, T10.ubicacion as direccionBodega, T1.FECHA_NOTA_DEBITO, t10.descripcion as tienda
FROM SEARMEDICA.FACTURA_NOTA_DEBITO T1 LEFT JOIN SEARMEDICA.FACTURA T2
ON T1.ID_FACTURA = T2.ID_FACTURA LEFT JOIN SEARMEDICA.ESTADOS T3
ON T1.ID_ESTADO = T3.ID_ESTADO LEFT JOIN SEARMEDICA.MOTIVO_NOTA_DEBITO T4
ON T1.ID_MOTIVO_NOTA_DEBITO = T4.ID_MOTIVO_NOTA_DEBITO LEFT JOIN SEARMEDICA.FACTURA_ANULACION T5
ON T1.ID_ANULACION = T5.ID_ANULACION INNER JOIN SEARMEDICA.DETALLE_FACTURA_NOTA_DEBITO T6
ON T1.ID_NOTA_DEBITO = T6.ID_NOTA_DEBITO INNER JOIN SEARMEDICA.DETALLE_FACTURA T8
ON T6.numero_linea = T8.numero_linea    INNER JOIN searmedica.bodega T10
ON T1.ID_BODEGA = T10.ID_BODEGA
and T6.id_producto = T8.id_producto  
and T6.ID_FACTURA = T8.ID_FACTURA INNER JOIN SEARMEDICA.PRODUCTO T9
ON T8.ID_PRODUCTO = T9.ID_PRODUCTO
WHERE T1.ID_NOTA_DEBITO =   $P{idNotaDebito}]]>
	</queryString>
