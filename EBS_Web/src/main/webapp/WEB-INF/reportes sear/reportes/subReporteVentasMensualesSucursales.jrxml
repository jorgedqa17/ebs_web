	<parameter name="fechaInicio" class="java.lang.String"/>
	<parameter name="fechaFinal" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
	TB.NOMBRESUCURSAL,
	SUM(TB.TOTAL_IMPUESTOS) AS TOTALIMPUESTOS ,
	SUM(TB.TOTAL_GRAVADO) AS TOTALGRAVADO ,
	SUM(TB.TOTAL_EXENTO) AS TOTALEXENTO,
	SUM(TB.TOTAL_DESCUENTOS) AS TOTALDESCUENTOS,
	SUM(TB.TOTAL_COMPROBANTE) AS TOTALCOMPROBANTES
FROM
	(
	SELECT
		T2.DESCRIPCION AS NOMBRESUCURSAL,
		T1.TOTAL_COMPROBANTE,
		T1.TOTAL_IMPUESTOS,
		T1.TOTAL_GRAVADO,
		T1.TOTAL_EXENTO,
		T1.TOTAL_DESCUENTOS
	FROM
		SEARMEDICA.FACTURA T1
	INNER JOIN SEARMEDICA.BODEGA T2 ON
		T1.ID_BODEGA = T2.ID_BODEGA
	WHERE
	    TO_DATE(TO_CHAR(T1.FECHA_FACTURA, 'DD/MM/YYYY'),'DD/MM/YYYY') BETWEEN TO_DATE(  $P{fechaInicio}  ,'DD/MM/YYYY')  AND TO_DATE(  $P{fechaFinal}  ,'DD/MM/YYY')  
		AND T1.ID_TIPO_FACTURA IN( 1, 4 )
		AND T1.ESTADO_FACTURA NOT IN (8)) TB
GROUP BY
	TB.NOMBRESUCURSAL
]]>
	</queryString>
