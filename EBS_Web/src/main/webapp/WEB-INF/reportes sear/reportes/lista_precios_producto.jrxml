	<parameter name="id_producto" class="java.lang.Long"/>
	<queryString>
		<![CDATA[SELECT t2.descripcion,t1.precio
FROM searmedica.producto_precios t1 inner join searmedica.tipos_precios t2 
on t1.id_tipo = t2.id_tipo
where id_producto =  $P{id_producto}]]>
	</queryString>
