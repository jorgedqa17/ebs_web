	</field>
	<field name="clave" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="clave"/>
	</field>
	<field name="total_comprobante" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.label" value="total_comprobante"/>
	</field>
	<field name="monto_restante" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.label" value="monto_restante"/>
	</field>
	<field name="numero_cedula" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="numero_cedula"/>
	</field>
	<field name="nombre" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="nombre"/>
	</field>
	<field name="fecha_factura" class="java.sql.Timestamp">
		<property name="com.jaspersoft.studio.field.label" value="fecha_factura"/>
	</field>
	<variable name="totalFacturas" class="java.math.BigDecimal" resetType="None" incrementType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{total_comprobante}]]></variableExpression>
	</variable>
	<variable name="totalRestante" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{monto_restante}]]></variableExpression>
	</variable>
	<variable name="totalPagado" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$V{totalFacturas}.subtract($V{totalRestante} )]]></variableExpression>
	</variable>
