<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="estado_cuenta_cliente" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="93fcb2b0-6557-47f5-b841-f6683c6e7fc3">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SearMedica_Desarrollo"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="166"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="829"/>
	<parameter name="idCliente" class="java.lang.Long"/>
	<parameter name="rutaImagen" class="java.lang.String"/>
	<parameter name="idCondicionVenta" class="java.lang.Long"/>
	<parameter name="rutaSubReportes" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT DISTINCT T1.ID_FACTURA, t1.fecha_factura + CAST(t1.plazo_credito|| 'days' AS INTERVAL) AS FECHA_VENCIMIENTO, T1.PLAZO_CREDITO, T1.NUMERO_CONSECUTIVO, T1.CLAVE, T1.TOTAL_COMPROBANTE, T1.MONTO_RESTANTE, T4.NUMERO_CEDULA, COALESCE(T4.NOMBRE,'') ||' '||COALESCE(T4.PRIMER_APELLIDO,'')||' '||COALESCE(T4.SEGUNDO_APELLIDO,'') AS NOMBRE , T1.FECHA_FACTURA
FROM SEARMEDICA.FACTURA T1  INNER JOIN SEARMEDICA.CLIENTE T3
ON T1.ID_CLIENTE = T3.ID_CLIENTE INNER JOIN SEARMEDICA.PERSONA T4
ON T3.NUMERO_CEDULA = T4.NUMERO_CEDULA
WHERE T1.ID_CLIENTE =    $P{idCliente} 
AND T1.ID_COND_VENTA =  $P{idCondicionVenta} 
AND T1.CLAVE IS NOT NULL
--AND T1.FACTURA_CANCELADA =0
AND T1.ID_ANULACION IS NULL
GROUP BY T1.ID_FACTURA,  T4.NUMERO_CEDULA]]>
	</queryString>
