	<parameter name="idFactura" class="java.lang.Long"/>
	<queryString>
		<![CDATA[SELECT T2.ID_RECIBO, T2.MONTO_PAGO, T2.FECHA AS FECHA_RECIBO, T2.CONCEPTO_RECIBO , t2.es_recibo_manual, t2.numero_recibo_manual, t3.descripcion
FROM SEARMEDICA.RECIBO T2 inner join searmedica.estados t3 on t2.id_estado = t3.id_estado WHERE ID_FACTURA = $P{idFactura}]]>
	</queryString>
