<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="listado_productos" pageWidth="1050" pageHeight="842" orientation="Landscape" columnWidth="1010" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="de884568-4598-4693-a8f0-9075fbc32806">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SearMedica_Produccion"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="312"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="683"/>
	<queryString>
		<![CDATA[SELECT t1.id_producto,t1.descripcion,t1.codigo_barras, t2.descripcion as unidad_medida, t3.descripcion as tipo_producto, 
       (CASE WHEN t1.ind_exonerado=1 THEN 'Producto Exonerado'
            WHEN t1.ind_exonerado=0 THEN 'Producto No Exonerado'
       END) as producto_exonerado, t4.descripcion as impuesto_asociado, 
	   (CASE WHEN t1.activo=1 THEN 'Producto Activo'
            WHEN t1.activo=0 THEN 'Producto Inactivo'
       END) as estado_producto, t5.nombre as proveedor, 
	   (CASE WHEN t1.ind_exento=1 THEN 'Producto Exento'
            WHEN t1.ind_exento=0 THEN 'Producto Gravado'
       END) as producto_gravado, t6.descripcion as tipo_tarifa_impuesto--,
	  -- t8.descripcion as tipo_precio,t7.precio
	FROM searmedica.producto t1 left join searmedica.unidad_medida t2
	on t1.id_unidad_medida = t2.id_unidad_medida
	left join searmedica.tipo_producto t3
	on t1.id_tipo_producto = t3.id_tipo_producto
	left join searmedica.impuesto t4 on t1.id_impuesto = t4.id_impuesto
	left join searmedica.proovedor t5 on t1.id_proovedor = t5.id_proveedor
	left join searmedica.tipo_tarifa_impuesto t6 on t1.id_tipo_tarifa_impuesto = t6.id_tipo_tarifa_impuesto
	--left join searmedica.producto_precios t7 on t1.id_producto = t7.id_producto 
	--left join searmedica.tipos_precios t8 on t7.id_tipo = t8.id_tipo
	where t1.activo = 1
	order by t1.activo desc, t1.descripcion asc]]>
	</queryString>
