	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SearMedica_Produccion"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="322"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="667"/>
	<parameter name="fechaInicio" class="java.lang.String"/>
	<parameter name="fechaFinal" class="java.lang.String"/>
	<parameter name="rutaSubReportes" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT TB.* FROM (
SELECT  T6.DESCRIPCION AS LOGIN, T1.NUMERO_CONSECUTIVO,T2.DESCRIPCION, T1.TOTAL_COMPROBANTE ,
	T1.NOMBRE_CLIENTE_FANTASIA,
	coalesce(t5.nombre,'') ||' '||coalesce(t5.primer_apellido,'')||' '||coalesce(t5.segundo_apellido,'') as nombre
	FROM SEARMEDICA.FACTURA T1 LEFT JOIN SEARMEDICA.ESTADOS T2 
ON T1.ESTADO_FACTURA = T2.ID_ESTADO LEFT JOIN SEARMEDICA.CLIENTE T3
	ON T1.ID_CLIENTE = T3.ID_CLIENTE LEFT JOIN SEARMEDICA.PERSONA T5
		ON T3.NUMERO_CEDULA = T5.NUMERO_CEDULA INNER JOIN SEARMEDICA.BODEGA T6
	  		ON T1.ID_BODEGA = T6.ID_BODEGA
where to_date(to_char(t1.fecha_factura, 'DD/MM/YYYY'),'DD/MM/YYYY') between to_date($P{fechaInicio},'DD/MM/YYYY')  and to_date($P{fechaFinal},'DD/MM/YYY') 
AND 	T1.NUMERO_CONSECUTIVO IS NOT NULL
GROUP BY  T6.DESCRIPCION, T1.NUMERO_CONSECUTIVO,T1.ID_CLIENTE, T5.NUMERO_CEDULA,T1.NOMBRE_CLIENTE_FANTASIA,T5.NOMBRE,t5.primer_apellido,t5.segundo_apellido,T2.DESCRIPCION, T1.TOTAL_COMPROBANTE
ORDER BY  T6.DESCRIPCION,T1.NUMERO_CONSECUTIVO,T2.DESCRIPCION ASC) TB
GROUP BY TB.LOGIN, TB.NUMERO_CONSECUTIVO,TB.NOMBRE_CLIENTE_FANTASIA,TB.NOMBRE,TB.DESCRIPCION, TB.TOTAL_COMPROBANTE]]>
	</queryString>
