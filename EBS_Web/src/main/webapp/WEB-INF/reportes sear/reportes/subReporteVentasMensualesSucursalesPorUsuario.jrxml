	<parameter name="fechaInicio" class="java.lang.String"/>
	<parameter name="fechaFinal" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select tb.login, SUM(tb.TOTAL_IMPUESTOS) as totalImpuestos ,
	SUM(TB.TOTAL_GRAVADO) as totalGravado ,
	SUM(TB.TOTAL_EXENTO) as totalExento, 
	SUM(TB.TOTAL_DESCUENTOS) as totalDescuentos,
	SUM(tb.TOTAL_COMPROBANTE) as totalComprobantes
from (SELECT t1.LOGIN,  t1.total_comprobante, t1.TOTAL_IMPUESTOS, t1.TOTAL_GRAVADO, t1.TOTAL_EXENTO, t1.TOTAL_DESCUENTOS
			FROM SEARMEDICA.FACTURA T1 
			where to_date(to_char(t1.fecha_factura, 'DD/MM/YYYY'),'DD/MM/YYYY') between to_date( $P{fechaInicio} ,'DD/MM/YYYY')  and to_date( $P{fechaFinal} ,'DD/MM/YYY') 
		AND T1.ID_TIPO_FACTURA IN( 1, 4 )
		AND T1.ESTADO_FACTURA NOT IN (8)
			  ) 
tb GROUP BY tb.login]]>
	</queryString>
