	<queryString>
		<![CDATA[SELECT 
T1.ID_ANULACION, T1.CLAVE AS CLAVE, T1.NUMERO_CONSECUTIVO, T2.CLAVE AS CLAVE_FACTURA, T2.NUMERO_CONSECUTIVO AS NUM_CONSEC_FACTURA,
T5.CLAVE AS CLAVE_NOTA_DEBITO, T5.NUMERO_CONSECUTIVO AS NUMERO_CONSECUTIVO_NOTA_DEBITO,
T1.FECHA_EMISION, T3.DESCRIPCION AS ESTADO_DOCUMENTO, T4.DESCRIPCION AS MOTIVO_ANULACION, T1.MOTIVO_ANULACION AS RAZON_ANULACION, T1.FECHA_EMISION as fecha_emision2,
T8.CANTIDAD, T9.DESCRIPCION,T8.TOTAL_IMPUESTOS,  T8.PRECIO_NETO, T8.TOTAL_LINEA,
T1.TOTAL_NOTA_CREDITO, T1.TOTAL_IMPUESTO, T1.LOGIN,
T10.TELEFONO_1, T10.TELEFONO_2, T10.ubicacion as direccionBodega, T1.FECHA_ANULACION, t10.descripcion as tienda,
t11.id_cliente, t12.numero_cedula, t13.descripcion as tipoCedula, t12.correo_electronico, 
trim(COALESCE(t12.NOMBRE,'') ||' '||COALESCE(t12.PRIMER_APELLIDO,'')||' '||COALESCE(t12.SEGUNDO_APELLIDO,'')) AS NOMBRE, t12.nombre_fantasia as nombre_cliente_fantasia, t12.direccion , t12.telefono_1 as telefono_4, t12.telefono_2 as  telefono_3
FROM SEARMEDICA.FACTURA_ANULACION T1 LEFT JOIN SEARMEDICA.FACTURA T2
ON T1.ID_FACTURA = T2.ID_FACTURA LEFT JOIN SEARMEDICA.ESTADOS T3
ON T1.ID_ESTADO = T3.ID_ESTADO LEFT JOIN SEARMEDICA.MOTIVO_ANULACION T4
ON T1.ID_MOTIVO_ANULACION = T4.ID_MOTIVO_ANULACION LEFT JOIN SEARMEDICA.FACTURA_NOTA_DEBITO T5
ON T1.ID_NOTA_DEBITO = T5.ID_NOTA_DEBITO INNER JOIN SEARMEDICA.DETALLE_FACTURA_NOTA_CREDITO T6
ON T1.ID_ANULACION = T6.ID_ANULACION INNER JOIN SEARMEDICA.DETALLE_FACTURA T8
ON T6.numero_linea = T8.numero_linea   
and T6.id_producto = T8.id_producto  
and T6.ID_FACTURA = T8.ID_FACTURA INNER JOIN SEARMEDICA.PRODUCTO T9
ON T8.ID_PRODUCTO = T9.ID_PRODUCTO     INNER JOIN searmedica.bodega T10
ON T1.ID_BODEGA = T10.ID_BODEGA left join searmedica.cliente t11 
on t2.id_cliente = t11.id_cliente left join searmedica.persona t12
on t11.numero_cedula = t12.numero_cedula left join searmedica.tipo_cedula t13
on t12.id_tipo_cedula = t13.id_tipo_cedula 
where T1.ID_ANULACION =  $P{idAnulacion}]]>
	</queryString>
