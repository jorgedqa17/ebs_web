	<columnHeader>
		<band height="21">
			<line>
				<reportElement positionType="Float" x="0" y="20" width="554" height="1" uuid="701711b8-1304-4fdc-942a-dd4bf0afb359"/>
			</line>
			<staticText>
				<reportElement positionType="Float" x="0" y="0" width="190" height="20" uuid="a24cee4a-0202-409f-8a6d-ee7bb7000942">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="b0b01e57-7fa7-4e88-b64f-66c5fb3e3f75"/>
				</reportElement>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font size="10" isBold="true"/>
				</textElement>
				<text><![CDATA[Descripción]]></text>
